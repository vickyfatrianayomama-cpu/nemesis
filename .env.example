# ==========================================
# NEMESIS DASHBOARD CONFIGURATION
# ==========================================

# --- Environment & Server ---
# Application environment (development | production)
NODE_ENV=production

# The port the application will bind to
PORT=3000

# Allowed CORS origins (use commas for multiple origins, or * for all)
CORS_ORIGIN=*


# --- Data & Asset Paths ---
# Directory holding runtime data files (SQLite database, dumps).
# Default: data
# DATA_DIR=data

# Path to the primary SQLite database
SQLITE_PATH=data/dashboard.sqlite

# Directory containing the raw audit JSON datasets
AUDIT_DATASET_DIR=dataset

# Year of the audit dataset to ingest (matches the year-NNNN.part-* file prefix).
# Default: 2026
# AUDIT_DATASET_YEAR=2026

# Root directory holding the MapLibre GeoJSON structural data
GEO_ROOT_PATH=seed/geo

# Directory of district-level GeoJSON files.
# Default: ${GEO_ROOT_PATH}/03-districts
# GEOJSON_PATH=seed/geo/03-districts

# Directory of province-only GeoJSON files.
# Default: ${GEO_ROOT_PATH}/02-provinces/province-only
# PROVINCE_GEOJSON_PATH=seed/geo/02-provinces/province-only
